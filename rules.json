rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Data_Admin: siapa pun boleh baca; tulis dibatasi hanya ke field tertentu
    match /Data_Admin/{docId} {
      allow get, list: if true;
      allow create, update: if request.resource.data.keys().hasOnly(["Email", "Password", "Role"]);
      allow delete: if true;
    }

    // Data_Siswa (DPT - legacy)
    match /Data_Siswa/{docId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }

    // Data_Peserta (DPT) — menggantikan Data_Siswa
    match /Data_Peserta/{docId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }

    // Calon Formatur
    match /Data_Calon_Formatur/{docId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }

    // Bilik Voting
    match /BilikVoting/{docId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }

    // Total voting
    match /TotalSudahVoting/{docId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }
    match /TotalBelumVoting/{docId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }

    // Landing page content/status
    match /LandingContent/{docId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }
    match /LandingPage/{docId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }

    // Jabatan formatur terpilih
    match /JabatanFormatur/{docId} {
      allow get, list: if true;
      allow create, update, delete: if true;
    }

    // Error log
    match /error/{docId} {
      allow get, list, create, update, delete: if true;
    }

    // Koleksi lain: blokir
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
